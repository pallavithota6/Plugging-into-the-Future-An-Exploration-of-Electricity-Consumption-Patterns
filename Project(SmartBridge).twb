    <dashboard name='Story on Electricity Consumption in India' type='storyboard'>
      <style>
        <style-rule element='story-description'>
          <format attr='font-weight' value='bold' />
        </style-rule>
      </style>
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98120' id='1' param='vert' removable='false' type-v2='layout-flow' w='99034' x='483' y='940'>
            <zone h='4935' id='3' type-v2='title' w='99034' x='483' y='940' />
            <zone h='11868' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99034' x='483' y='5875' />
            <zone h='81317' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99034' x='483' y='17743'>
              <flipboard active-id='11' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Electricity Consumption by  Indian States in 2019' captured-sheet='2019 State Consumption' id='1'>
                    <capturedDeltas>
                      <worksheet name='2019 State Consumption'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.1vjvead0dy0u4511ldd5m0svg06g].[avg:latitude:qk]' field-type='quantitative' max='4592074.8424903713' min='44647.936822661199' projection='EPSG:3857' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='0' field='[federated.1vjvead0dy0u4511ldd5m0svg06g].[avg:longitude:qk]' field-type='quantitative' max='11292500.532496376' min='6289115.0132244164' projection='EPSG:3857' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Electricity Consumption by Indian States in 2020' captured-sheet='2020 State Consumption' id='2'>
                    <capturedDeltas>
                      <worksheet name='2020 State Consumption'>
                        <style delta-type='added'>
                          <style-rule element='axis'>
                            <encoding attr='space' class='0' field='[federated.1vjvead0dy0u4511ldd5m0svg06g].[Latitude (generated)]' field-type='quantitative' max='4849557.6512352433' min='-267160.6463300616' projection='EPSG:3857' range-type='fixed' scope='rows' type='space' />
                            <encoding attr='space' class='0' field='[federated.1vjvead0dy0u4511ldd5m0svg06g].[Longitude (generated)]' field-type='quantitative' max='11638398.068356821' min='6008639.7968551302' projection='EPSG:3857' range-type='fixed' scope='cols' type='space' />
                          </style-rule>
                        </style>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Bar Plots for total Electricityin Year 2019 and 2020 Consumption by Indian States ' captured-sheet='Total Consumption' id='3' />
                  <story-point caption='Region wise plot clearly states consumption in 2019 is more as compared to 2020 ' captured-sheet='Yearwise Consumption' id='4' />
                  <story-point caption='Plot defines top consumption by Indian States in Year 2019 and 2020' captured-sheet='Top N' id='5' />
                  <story-point caption='Plot defines Bottom Consumption by Indain States in Year 2019 and 2020' captured-sheet='Bottom N' id='6' />
                  <story-point caption='In Year 2019,Electricity Consumption by Indian was highest  in July follwed by August and December ' captured-sheet='2019 Monthwise Consumption' id='7' />
                  <story-point caption='In Year 2020,Electricity Consumption was highest in January' captured-sheet='2020 Monthwise Consumption' id='8' />
                  <story-point caption='Electricity Consumption for Period of March to June was less in 2020 compared to 2019 because of lockdown' captured-sheet='Usage before and during lockdown' id='9' />
                  <story-point caption='The most Electricity Consumption is  highest in WR Region whereas NER has less Consumption   ' captured-sheet='Total Region Consumption' id='10' />
                  <story-point caption='Maharashtra has Highest usage of Electricity and its peak on Q3 of 2019 and its  lowest consumption is in Q4 of 2020 ' captured-sheet='Metro City States' id='11' />
                  <story-point caption='In Year 2019,Electricity Consumption was more as compared to 2020 in India ' captured-sheet='Usage By Year' id='12' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
